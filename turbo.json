{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"],
      "inputs": [
        "src/**/*.tsx?",
        "src/**/*.ts",
        "test/**/*.ts",
        "jest.config.js",
        "jest.config.ts"
      ]
    },
    "test:coverage": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"],
      "inputs": [
        "src/**/*.tsx?",
        "src/**/*.ts",
        "test/**/*.ts",
        "jest.config.js",
        "jest.config.ts"
      ]
    },
    "clean": {
      "cache": false
    }
  }
}
